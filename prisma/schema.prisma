generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ConversationMode {
  CHAT
  AGENT
  CODING
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RunStatus {
  PENDING
  RUNNING
  AWAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CodingSessionStatus {
  PROVISIONING
  READY
  RUNNING
  PAUSED
  ERROR
  CLOSED
}

enum RepoProvider {
  GITHUB
}

enum AttachmentKind {
  IMAGE
  PDF
  DOCUMENT
  OTHER
}

model UserProfile {
  userId              String             @id
  email               String             @unique
  fullName            String?
  avatarUrl           String?
  preferencesJson     Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  conversations       Conversation[]
  mainAgentSessions   MainAgentSession[]
  codingSessions      CodingSession[]
  memoryEntries       MemoryEntry[]
  repoBindings        RepoBinding[]
  workspaceSnapshots  WorkspaceSnapshot[]
  githubInstallations GithubInstallation[]
  mcpConnectors       McpConnector[]
  scheduledPrompts    ScheduledPrompt[]
}

model Conversation {
  id                String            @id @default(uuid())
  userId            String
  title             String
  defaultMode       ConversationMode  @default(AGENT)
  isStarred         Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              UserProfile       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  mainAgentSession  MainAgentSession?
  messages          Message[]
  runs              AgentRun[]
  codingSessions    CodingSession[]
  repoBindingId     String?
  repoBinding       RepoBinding?      @relation(fields: [repoBindingId], references: [id], onDelete: SetNull)
  attachments       Attachment[]
  memoryEntries     MemoryEntry[]
  scheduledPrompt   ScheduledPrompt?

  @@index([userId, updatedAt])
}

model MainAgentSession {
  id              String        @id @default(uuid())
  conversationId  String        @unique
  userId          String
  anthropicModel  String?
  metadataJson    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user            UserProfile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  runs            AgentRun[]

  @@index([userId, updatedAt])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  role           MessageRole
  contentJson    Json
  createdAt      DateTime      @default(now())
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Attachment {
  id               String        @id @default(uuid())
  conversationId   String?
  runId            String?
  kind             AttachmentKind @default(OTHER)
  filename         String
  mediaType        String
  sizeBytes        Int?
  anthropicFileId  String?
  storageUrl       String?
  metadataJson     Json?
  createdAt        DateTime      @default(now())
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  run              AgentRun?     @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, kind, createdAt])
  @@index([runId, createdAt])
}

model RepoBinding {
  id                  String             @id @default(uuid())
  userId              String
  provider            RepoProvider       @default(GITHUB)
  installationId      String?
  repoOwner           String
  repoName            String
  repoFullName        String
  defaultBranch       String?
  metadataJson        Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  user                UserProfile        @relation(fields: [userId], references: [userId], onDelete: Cascade)
  conversations       Conversation[]
  codingSessions      CodingSession[]
  workspaceSnapshots  WorkspaceSnapshot[]
  secrets             RepoSecret[]
  scheduledPrompts    ScheduledPrompt[]

  @@unique([userId, provider, repoFullName])
  @@index([userId, updatedAt])
}

model RepoSecret {
  id              String      @id @default(uuid())
  repoBindingId   String
  key             String
  encryptedValue  String
  valueIv         String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  repoBinding     RepoBinding @relation(fields: [repoBindingId], references: [id], onDelete: Cascade)

  @@unique([repoBindingId, key])
  @@index([repoBindingId])
}

model CodingSession {
  id                  String               @id @default(uuid())
  conversationId      String
  userId              String
  repoBindingId       String?
  sandboxId           String?
  claudeSdkSessionId  String?
  workspacePath       String?
  branch              String?
  status              CodingSessionStatus  @default(PROVISIONING)
  lastActiveAt        DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  conversation        Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user                UserProfile          @relation(fields: [userId], references: [userId], onDelete: Cascade)
  repoBinding         RepoBinding?         @relation(fields: [repoBindingId], references: [id], onDelete: SetNull)
  runs                AgentRun[]

  @@index([conversationId, updatedAt])
  @@index([userId, updatedAt])
  @@index([repoBindingId])
}

model AgentRun {
  id                  String             @id @default(uuid())
  conversationId      String
  userId              String
  mainAgentSessionId  String?
  codingSessionId     String?
  status              RunStatus          @default(PENDING)
  userPrompt          String
  finalText           String?
  finalMessageJson    Json?
  metadataJson        Json?
  model               String?
  inputTokens         Int?
  outputTokens        Int?
  cacheReadTokens     Int?
  cacheWriteTokens    Int?
  costUsd             Float?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  completedAt         DateTime?
  cancelledAt         DateTime?
  conversation        Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  mainAgentSession    MainAgentSession?  @relation(fields: [mainAgentSessionId], references: [id], onDelete: SetNull)
  codingSession       CodingSession?     @relation(fields: [codingSessionId], references: [id], onDelete: SetNull)
  events              RunEvent[]
  approvals           RunApproval[]
  attachments         Attachment[]
  scheduledExecution  ScheduledExecution?

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model RunEvent {
  id          String    @id @default(uuid())
  runId       String
  type        String
  payloadJson Json?
  ts          DateTime  @default(now())
  run         AgentRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, ts])
  @@index([runId, type])
}

model RunApproval {
  id            String          @id @default(uuid())
  runId         String
  kind          String
  title         String
  reason        String?
  status        ApprovalStatus  @default(PENDING)
  proposalJson  Json?
  responseJson  Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  resolvedAt    DateTime?
  run           AgentRun        @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, status, createdAt])
}

model MemoryEntry {
  id             String        @id @default(uuid())
  userId         String
  conversationId String?
  key            String
  value          String
  metadataJson   Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           UserProfile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId, key])
  @@index([userId, conversationId, updatedAt])
  @@index([conversationId, createdAt])
}

model WorkspaceSnapshot {
  id             String        @id @default(uuid())
  userId         String
  repoBindingId  String?
  sandboxId      String?
  snapshotId     String?
  label          String?
  metadataJson   Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           UserProfile   @relation(fields: [userId], references: [userId], onDelete: Cascade)
  repoBinding    RepoBinding?  @relation(fields: [repoBindingId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([repoBindingId, createdAt])
}

enum ScheduledPromptStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model ScheduledPrompt {
  id              String                @id @default(uuid())
  userId          String
  conversationId  String?               @unique
  repoBindingId   String?
  prompt          String
  cronExpression  String
  timezone        String                @default("UTC")
  status          ScheduledPromptStatus @default(ACTIVE)
  maxRuns         Int?
  totalRuns       Int                   @default(0)
  nextRunAt       DateTime?
  lastRunAt       DateTime?
  preferencesJson Json?
  mcpConnectorIds Json?
  label           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user            UserProfile           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  conversation    Conversation?         @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  repoBinding     RepoBinding?          @relation(fields: [repoBindingId], references: [id], onDelete: SetNull)
  executions      ScheduledExecution[]

  @@index([userId, status])
  @@index([status, nextRunAt])
  @@index([userId, nextRunAt])
}

model ScheduledExecution {
  id                String          @id @default(uuid())
  scheduledPromptId String
  runId             String?         @unique
  status            RunStatus       @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  errorMessage      String?
  createdAt         DateTime        @default(now())

  scheduledPrompt   ScheduledPrompt @relation(fields: [scheduledPromptId], references: [id], onDelete: Cascade)
  run               AgentRun?       @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([scheduledPromptId, createdAt])
}

enum McpConnectorStatus {
  ACTIVE
  NEEDS_AUTH
  ERROR
  DISABLED
}

model McpConnector {
  id                   String              @id @default(uuid())
  userId               String
  name                 String
  url                  String
  encryptedAccessToken String?
  accessTokenIv        String?
  encryptedRefreshToken String?
  refreshTokenIv       String?
  tokenExpiresAt       DateTime?
  oauthClientId        String?
  oauthClientSecret    String?
  oauthServerMetadata  Json?
  status               McpConnectorStatus  @default(ACTIVE)
  lastError            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 UserProfile         @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, status])
}

model GithubInstallation {
  id                    String      @id @default(uuid())
  userId                String
  installationId        String
  accountLogin          String?
  metadataJson          Json?
  encryptedUserToken    String?
  userTokenIv           String?
  encryptedRefreshToken String?
  refreshTokenIv        String?
  userTokenExpiresAt    DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  user                  UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, installationId])
  @@index([installationId])
  @@index([userId, updatedAt])
}
