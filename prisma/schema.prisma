generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderId {
  OPENAI
  ANTHROPIC
}

enum RunMode {
  CHAT
  AGENT
  CODING
}

enum ExecutionTarget {
  VERCEL
  E2B
}

enum RunStatus {
  CREATED
  AWAITING_APPROVAL
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ConnectorType {
  REST
  GRAPHQL
  MCP
}

enum ConnectorAuthType {
  NONE
  API_KEY
  BEARER
  OAUTH2
}

enum ServerType {
  REMOTE
  LOCAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ToolPublishState {
  DRAFT
  PUBLISHED
  DISABLED
}

model UserProfile {
  userId    String   @id @map("user_id")
  email     String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model ProviderCredential {
  id               String     @id @default(cuid())
  userId           String     @map("user_id")
  provider         ProviderId
  encryptedKeyBlob String     @map("encrypted_key_blob")
  status           String
  validatedAt      DateTime?  @map("validated_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@unique([userId, provider], map: "provider_credentials_user_provider_key")
  @@index([userId])
  @@map("provider_credentials")
}

model ConnectorConfig {
  id            String            @id @default(cuid())
  userId        String            @map("user_id")
  name          String
  connectorType ConnectorType     @map("connector_type")
  baseUrl       String?           @map("base_url")
  authType      ConnectorAuthType @map("auth_type")
  configJson    Json              @map("config_json")
  status        String
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  secrets     ConnectorSecret[]
  customTools CustomTool[]

  @@index([userId])
  @@map("connector_configs")
}

model ConnectorSecret {
  id                  String    @id @default(cuid())
  connectorId         String    @map("connector_id")
  encryptedSecretBlob String    @map("encrypted_secret_blob")
  keyVersion          String    @map("key_version")
  lastValidatedAt     DateTime? @map("last_validated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  connector ConnectorConfig @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId])
  @@map("connector_secrets")
}

model CustomTool {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  connectorId      String           @map("connector_id")
  name             String
  description      String
  inputSchemaJson  Json             @map("input_schema_json")
  outputSchemaJson Json             @map("output_schema_json")
  executionTarget  ExecutionTarget  @map("execution_target")
  policyJson       Json             @map("policy_json")
  enabled          Boolean          @default(true)
  publishState     ToolPublishState @default(DRAFT) @map("publish_state")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  connector ConnectorConfig    @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  versions  CustomToolVersion[]

  @@index([userId])
  @@index([connectorId])
  @@unique([userId, name], map: "custom_tools_user_name_key")
  @@map("custom_tools")
}

model CustomToolVersion {
  id        String   @id @default(cuid())
  toolId    String   @map("tool_id")
  version   Int
  specJson  Json     @map("spec_json")
  createdAt DateTime @default(now()) @map("created_at")

  tool CustomTool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, version], map: "custom_tool_versions_tool_version_key")
  @@index([toolId])
  @@map("custom_tool_versions")
}

model ModelCatalog {
  id            String     @id @default(cuid())
  provider      ProviderId
  modelId       String     @map("model_id")
  displayName   String     @map("display_name")
  supportsTools Boolean    @default(true) @map("supports_tools")
  tier          String
  enabled       Boolean    @default(true)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@unique([provider, modelId], map: "model_catalog_provider_model_key")
  @@map("model_catalog")
}

model ModelAlias {
  id        String     @id @default(cuid())
  alias     String
  provider  ProviderId
  modelId   String     @map("model_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@unique([alias, provider], map: "model_aliases_alias_provider_key")
  @@map("model_aliases")
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  defaultMode RunMode  @default(CHAT) @map("default_mode")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  messages Message[]
  runs     AgentRun[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String
  contentJson    Json     @map("content_json")
  modelId        String?  @map("model_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model AgentRun {
  id               String          @id @default(cuid())
  userId           String          @map("user_id")
  conversationId   String          @map("conversation_id")
  mode             RunMode
  executionTarget  ExecutionTarget @map("execution_target")
  status           RunStatus       @default(CREATED)
  approvedMcp      Json?           @map("approved_mcp")
  approvedTools    Json?           @map("approved_tools")
  usageJson        Json?           @map("usage_json")
  finalMessageJson Json?           @map("final_message_json")
  cancelledAt      DateTime?       @map("cancelled_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  endedAt          DateTime?       @map("ended_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  events       RunEvent[]
  approvals    RunApproval[]

  @@index([userId])
  @@index([conversationId])
  @@map("agent_runs")
}

model RunEvent {
  id          String   @id @default(cuid())
  runId       String   @map("run_id")
  ts          DateTime @default(now())
  type        String
  payloadJson Json     @map("payload_json")

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_events")
}

model RunApproval {
  id           String         @id @default(cuid())
  runId        String         @map("run_id")
  kind         String
  proposalJson Json           @map("proposal_json")
  status       ApprovalStatus @default(PENDING)
  resolvedAt   DateTime?      @map("resolved_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_approvals")
}

model MCPServer {
  id         String     @id @default(cuid())
  userId     String     @map("user_id")
  serverType ServerType @map("server_type")
  configJson Json       @map("config_json")
  status     String
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@index([userId])
  @@map("mcp_servers")
}

model GithubInstallation {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  installationId String   @map("installation_id")
  accountJson    Json     @map("account_json")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, installationId], map: "github_installations_user_installation_key")
  @@index([userId])
  @@map("github_installations")
}

model CodingSession {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  runId         String?  @map("run_id")
  repoFullName  String   @map("repo_full_name")
  baseBranch    String   @map("base_branch")
  workingBranch String   @map("working_branch")
  sandboxId     String?  @map("sandbox_id")
  prUrl         String?  @map("pr_url")
  status        String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("coding_sessions")
}

model Artifact {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  runId       String?  @map("run_id")
  kind        String
  storagePath String   @map("storage_path")
  metaJson    Json?    @map("meta_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([runId])
  @@map("artifacts")
}
