{
  "name": "@relay-ai/coding-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "relay-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --outDir dist --clean",
    "dev": "tsup src/cli.ts --format esm --target node20 --outDir dist --watch",
    "build:template": "pnpm build && tsx build-template.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "e2b": "^2.14.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
